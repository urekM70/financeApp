# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_NAME=finance_db
DB_USER=finance_user
DB_PASSWORD=your_secure_password

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=true

# LLM Configuration
# If you are using a self-hosted LLM that is compatible with the OpenAI API,
# you can set the OPENAI_BASE_URL to your local endpoint.
OPENAI_API_KEY=your_openai_api_key
OPENAI_BASE_URL=https://api.openai.com/v1

# OpenRouter Configuration
OPENROUTER_API_KEY=your_openrouter_api_key

# Zhipu AI (GLM-4) Configuration
ZHIPUAI_API_KEY=your_zhipu_ai_api_key

# Default model to use for generation tasks (can be from any provider)
LLM_MODEL=qwen/qwen3-next-80b-a3b-instruct:free
